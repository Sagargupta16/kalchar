---
import { getCollection } from 'astro:content';
import { brand, styles } from '@/lib/site';
import { placeholderDataUri } from '@/lib/placeholder';
import { artworkUrl, type Artwork } from '@/lib/images';

const all = await getCollection('artworks');
const baseUrl = import.meta.env.BASE_URL;

const featured = (all.find((e) => (e.data as Artwork).featured)?.data ??
  all[0]?.data) as Artwork | undefined;

const heroImage = featured
  ? (featured.image
      ? artworkUrl(featured, baseUrl)
      : placeholderDataUri({ title: featured.title, style: featured.style, width: 720, height: 900 }))
  : placeholderDataUri({ title: brand.title, style: 'Madhubani', width: 720, height: 900 });

const heroLabel = featured ? `${featured.title} · ${featured.style}` : '';
---
<section class="relative overflow-hidden border-b border-[var(--color-line)]">
  <div class="container-x grid gap-10 py-16 sm:gap-12 sm:py-24 md:grid-cols-12 md:items-center md:gap-10 md:py-32">
    <div class="stagger md:col-span-7">
      <p class="t-eyebrow reveal mb-4 sm:mb-5">{brand.tagline}</p>
      <h1 class="t-display reveal text-5xl text-[var(--color-ink)] sm:text-6xl md:text-[7rem] md:leading-[0.95] lg:text-[7.5rem]">
        <span class="block">
          {brand.headline.latinPrefix}<span
            class="font-devanagari not-italic text-[var(--color-accent)]"
          >{brand.headline.devanagariCore}</span>
        </span>
        <span class="block text-[0.55em] tracking-[var(--tracking-display)] text-[var(--color-muted)] sm:text-[0.5em]">
          <span class="not-italic">{brand.headline.connector}</span>{' '}
          <span class="text-[var(--color-ink)]">{brand.headline.suffix}</span>
        </span>
      </h1>
      <p class="t-lead reveal mt-5 max-w-xl sm:mt-7">{brand.description}</p>
      <ul class="reveal mt-7 flex flex-wrap gap-x-2 gap-y-2 sm:mt-10 sm:gap-x-3">
        {styles.map((s) => (
          <li class="t-meta rounded-full border border-[var(--color-line)] px-3 py-1">{s}</li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-5">
      <div class="motion-float mx-auto w-full max-w-md md:max-w-none">
        <div
          id="hero-frame"
          class="parallax-frame motion-glow relative aspect-[3/4] w-full"
        >
          <div
            class="absolute inset-0 border border-[var(--color-line)] bg-[var(--color-bg-soft)]"
            style="transform: translate(-1rem, 1rem) translateZ(-30px);"
          ></div>
          <div
            class="relative h-full w-full overflow-hidden border border-[var(--color-line)]"
            data-loaded="false"
          >
            <span class="skel" aria-hidden="true"></span>
            <img
              src={heroImage}
              alt={heroLabel || 'Hero artwork'}
              class="motion-kenburns img-fade h-full w-full object-cover"
              loading="eager"
              decoding="async"
              onload="this.classList.add('is-loaded'); this.parentElement.dataset.loaded='true';"
            />
          </div>
          {heroLabel && <p class="t-meta absolute -bottom-6 right-0">{heroLabel}</p>}
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      if (typeof window === 'undefined') return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (window.matchMedia('(hover: none)').matches) return;
      const frame = document.getElementById('hero-frame');
      if (!frame) return;
      // The first child div is the offset shadow; the second is the image wrapper.
      const children = frame.children;
      const shadow = children[0];
      const inner = children[1];
      if (!inner || !shadow) return;
      let raf = 0;
      function onMove(e) {
        const r = frame.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          inner.style.transform = `perspective(1000px) rotateX(${(-y * 6).toFixed(2)}deg) rotateY(${(x * 8).toFixed(2)}deg)`;
          shadow.style.transform = `perspective(1000px) translate(${(x * 18 - 16).toFixed(1)}px, ${(y * 18 + 16).toFixed(1)}px) translateZ(-30px)`;
        });
      }
      function reset() {
        inner.style.transform = '';
        shadow.style.transform = 'translate(-1rem, 1rem) translateZ(-30px)';
      }
      frame.addEventListener('mousemove', onMove);
      frame.addEventListener('mouseleave', reset);
    })();
  </script>
</section>
