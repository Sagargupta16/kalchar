---
// Marks any .img-fade image that finished loading from cache as loaded,
// so its skeleton hides without waiting for an onload event that never fires.
---
<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;
    function settle(img) {
      if (!img.classList.contains('is-loaded')) {
        img.classList.add('is-loaded');
      }
      const wrap = img.parentElement;
      if (wrap && wrap.dataset.loaded !== 'true') {
        wrap.dataset.loaded = 'true';
      }
    }
    function sweep() {
      document.querySelectorAll('img.img-fade').forEach((img) => {
        if (img.complete && img.naturalHeight > 0) settle(img);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', sweep, { once: true });
    } else {
      sweep();
    }
  })();
</script>
