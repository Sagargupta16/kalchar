---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Marquee from '@/components/ui/Marquee.astro';
import About from '@/components/sections/About.astro';
import Work from '@/components/sections/Work.astro';
import Workshops from '@/components/sections/Workshops.astro';
import CustomOrders from '@/components/sections/CustomOrders.astro';
import Contact from '@/components/sections/Contact.astro';
import { buildHomepageGraph } from '@/lib/structured-data';
import { artworkUrl, type Artwork } from '@/lib/images';

const artworks = await getCollection('artworks');
const baseUrl = import.meta.env.BASE_URL;
const siteUrl = (Astro.site ?? Astro.url).toString();

// Pick the same featured piece Hero.astro will render -- preload it for LCP.
const featured = (artworks.find((e) => (e.data as Artwork).featured)?.data ??
  artworks[0]?.data) as Artwork | undefined;
const preloadImage = featured?.image
  ? new URL(artworkUrl(featured, baseUrl), siteUrl).toString()
  : undefined;

const jsonLd = buildHomepageGraph({ artworks, siteUrl, baseUrl });
---
<BaseLayout jsonLd={jsonLd} preloadImage={preloadImage}>
  <Hero />
  <Marquee />
  <Work />
  <About />
  <Workshops />
  <CustomOrders />
  <Contact />
</BaseLayout>
