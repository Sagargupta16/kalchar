# Copy to .env.local (gitignored) and fill in real values. Never commit secrets.
# Full instructions: docs/PHASE-2-SETUP.md Part 1.
#
# NOTE: these are only consumed on the Phase 2 branch (Vercel deploy). The
# Phase 1 static export (GitHub Pages, main) does not read them.

# --- Auth.js v5 (Google sign-in) ---
# Generate AUTH_SECRET with `npx auth secret`. Google ID/secret from the
# Google Cloud OAuth client. The admin allowlist is NOT here -- it lives in the
# `maintainers` DB table, seeded with sg85207@gmail.com (root) and editable
# from the /admin panel.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Neon (Postgres) database ---
# Pooled connection string from the Neon dashboard (matches the ledger-sync setup).
DATABASE_URL=

# --- Cloudflare R2 (image storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kalchar-artworks
R2_PUBLIC_BASE_URL=
# Client-readable copy of the R2 public base (the gallery is a client
# component, so it reads NEXT_PUBLIC_*). Same value as R2_PUBLIC_BASE_URL.
NEXT_PUBLIC_IMAGE_BASE_URL=
