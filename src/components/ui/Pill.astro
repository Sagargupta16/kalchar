---
interface Props {
  active?: boolean;
  as?: 'button' | 'span' | 'li';
  class?: string;
  [key: string]: unknown;
}
const { active = false, as = 'span', class: className = '', ...rest } = Astro.props;
const Tag = as as 'button' | 'span' | 'li';

const base = 't-meta inline-flex items-center rounded-full border px-3 py-1 transition motion-safe:duration-300 motion-safe:ease-out';
const state = active
  ? 'border-[var(--color-ink)] bg-[var(--color-ink)] text-[var(--color-bg)]'
  : 'border-[var(--color-line)] text-[var(--color-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]';
---
<Tag class={`${base} ${state} ${className}`} {...rest}>
  <slot />
</Tag>
