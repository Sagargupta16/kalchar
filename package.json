{
	"name": "kalchar-by-megha",
	"version": "1.16.0",
	"private": true,
	"description": "Portfolio site for Megha Seth, traditional folk artist.",
	"license": "UNLICENSED",
	"packageManager": "pnpm@10.32.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "pnpm run optimize:images && next build && node scripts/prune-build.mjs",
		"preview": "pnpm run build && npx -y serve out",
		"start": "next start",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"format": "biome format --write",
		"typecheck": "tsc --noEmit",
		"optimize:images": "node scripts/optimize-images.mjs",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "tsx scripts/migrate-json-to-db.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1061.0",
		"@neondatabase/serverless": "^1.1.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"lenis": "^1.3.4",
		"lucide-react": "^0.473.0",
		"motion": "^12.0.0",
		"next": "^15.1.0",
		"next-auth": "5.0.0-beta.31",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-icons": "^5.6.0",
		"tailwind-merge": "^2.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@tailwindcss/postcss": "^4.0.0",
		"@types/node": "^22.10.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"playwright": "^1.60.0",
		"postcss": "^8.5.0",
		"sharp": "^0.34.0",
		"tailwindcss": "^4.0.0",
		"tsx": "^4.22.4",
		"typescript": "^5.7.0"
	}
}
