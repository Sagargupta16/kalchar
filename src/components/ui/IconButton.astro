---
interface Props {
  href?: string;
  ariaLabel: string;
  title?: string;
  size?: 'sm' | 'md';
  variant?: 'outline' | 'ghost';
  class?: string;
}
const {
  href,
  ariaLabel,
  title,
  size = 'md',
  variant = 'outline',
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'button';

const base = 'inline-grid place-items-center shrink-0 rounded-full transition motion-safe:duration-300 motion-safe:ease-out hover:text-[var(--color-accent)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-bg)] text-[var(--color-ink)]';

const sizes = {
  sm: 'h-8 w-8 text-sm',
  md: 'h-10 w-10 text-base',
};

const variants = {
  outline: 'border border-[var(--color-line)] hover:border-[var(--color-accent)] bg-transparent',
  ghost: 'bg-transparent hover:bg-[var(--color-bg-soft)]',
};

const classes = [base, sizes[size], variants[variant], className].join(' ');
---
<Tag
  {...href ? { href } : { type: 'button' }}
  aria-label={ariaLabel}
  title={title ?? ariaLabel}
  class={classes}
>
  <slot />
</Tag>
