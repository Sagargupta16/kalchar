---
/* A 3-5 swatch strip displayed under each gallery card. Reads like a museum
   palette caption: small uniform pills in the painting's actual pigments.
   Emits zero JS -- structure is just spans with inline background colors. */
interface Props {
  palette?: string[];
  fallback?: string;
  ariaLabel?: string;
}
const { palette, fallback, ariaLabel = 'Palette sampled from the artwork' } = Astro.props;
const swatches = palette && palette.length > 0
  ? palette
  : fallback
    ? [fallback]
    : [];
if (swatches.length === 0) return Astro.response;
---
<div class="chromacard" role="img" aria-label={ariaLabel}>
  {swatches.map((hex) => (
    <span style={`background:${hex};`} aria-hidden="true"></span>
  ))}
</div>
