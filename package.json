{
	"name": "folk-art-portfolio",
	"version": "1.5.1",
	"private": true,
	"type": "module",
	"description": "Portfolio website for Megha Seth, traditional artist.",
	"scripts": {
		"dev": "vite",
		"optimize:images": "node scripts/optimize-images.mjs",
		"generate:sitemap": "node scripts/generate-sitemap.mjs",
		"build": "pnpm run optimize:images && tsc -b && vite build && pnpm run generate:sitemap",
		"preview": "vite preview",
		"typecheck": "tsc -b",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"format": "biome format --write"
	},
	"license": "UNLICENSED",
	"packageManager": "pnpm@10.32.0",
	"engines": {
		"node": ">=20.18"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/cormorant-garamond": "^5.2.11",
		"@fontsource/tiro-devanagari-hindi": "^5.2.7",
		"@tailwindcss/vite": "^4.3.0",
		"lenis": "^1.3.23",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"tailwindcss": "^4.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.5.2",
		"sharp": "^0.34.5",
		"typescript": "^6.0.3",
		"vite": "^6.3.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"overrides": {
			"yaml@<2.8.3": "^2.8.3"
		}
	}
}
