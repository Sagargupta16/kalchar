---
import Section from '@/components/layout/Section.astro';
import { brand, sections } from '@/lib/site';
const a = sections.about;
---
<Section id="about" eyebrow={a.eyebrow} title={a.title} accent="var(--color-marigold)">
  <div class="grid gap-10 md:grid-cols-12">
    <div class="stagger space-y-5 md:col-span-8">
      {a.paragraphs.map((p, i) => (
        <p class:list={['t-body reveal', i === 0 && 'drop-cap']}>{p}</p>
      ))}
      <blockquote class="reveal mt-8 border-l-2 pl-5" style="border-color:var(--section-accent);">
        <p class="t-display text-2xl sm:text-3xl" style="color:var(--section-accent);">{a.pullQuote}</p>
      </blockquote>
      {/* Devanagari signature glyph -- "Iti" (इति), the closing flourish in
         classical manuscripts. Reads as a quiet sign-off in the artist's voice. */}
      <p class="reveal mt-2 text-right" aria-hidden="true">
        <span
          lang="hi"
          class="font-devanagari text-3xl"
          style="color:color-mix(in srgb, var(--section-accent) 70%, var(--color-muted));"
        >इति</span>
      </p>
    </div>
    <aside class="stagger space-y-3 md:col-span-4">
      <p class="t-meta reveal">Based in</p>
      <p class="t-body reveal">{brand.location}</p>
      <p class="t-meta reveal mt-6">{a.asideHeading}</p>
      <p class="t-body reveal">{a.asideBody}</p>
    </aside>
  </div>
</Section>
