---
import { brand, nav } from '@/lib/site';
import ThemeToggle from '@/components/ui/ThemeToggle';
const logoUrl = `${import.meta.env.BASE_URL}${brand.logo}`;
---
<header class="sticky top-0 z-40 border-b border-[var(--color-line)] bg-[var(--color-bg)]/85 backdrop-blur-md">
  {/* Top bar -- always visible: brand mark + theme toggle. */}
  <div class="container-x flex items-center justify-between gap-3 py-3 sm:gap-4 sm:py-4">
    <a
      href="#top"
      class="group flex shrink-0 items-center gap-2 transition sm:gap-3"
      aria-label={`${brand.logoAlt} -- home`}
    >
      <img
        src={logoUrl}
        alt=""
        width="40"
        height="40"
        loading="eager"
        decoding="async"
        class="h-8 w-8 rounded-full object-cover ring-1 ring-[var(--color-line)] transition group-hover:ring-[var(--color-accent)] sm:h-10 sm:w-10"
      />
      <span
        class="t-display text-lg leading-none text-[var(--color-ink)] transition group-hover:text-[var(--color-accent)] sm:text-xl"
        aria-hidden="true"
      >
        {brand.headline.latinPrefix}<span
          lang="hi"
          class="font-devanagari not-italic text-[var(--color-accent)]"
        >{brand.headline.devanagariCore}</span>
      </span>
    </a>

    {/* Desktop nav -- inline between brand and toggle on sm+. Hidden on mobile. */}
    <nav aria-label="Primary" class="hidden min-w-0 flex-1 sm:block">
      <ul class="flex items-center justify-end gap-5 md:gap-7">
        {nav.map((item) => (
          <li class="shrink-0">
            <a
              href={item.href}
              class="t-meta tracking-[0.16em] text-[var(--color-muted)] transition hover:text-[var(--color-accent)]"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <ThemeToggle client:load />
  </div>

  {/* Mobile nav -- full-width row beneath the top bar. Hidden on sm+. */}
  <nav aria-label="Primary mobile" class="border-t border-[var(--color-line)] sm:hidden">
    <ul class="container-x flex items-center justify-between gap-1 overflow-x-auto py-2.5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      {nav.map((item) => (
        <li class="shrink-0">
          <a
            href={item.href}
            class="block py-2 font-body text-[0.7rem] uppercase tracking-[0.06em] text-[var(--color-muted)] transition hover:text-[var(--color-accent)]"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
