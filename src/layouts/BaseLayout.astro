---
import '@/styles/globals.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ThemeScript from '@/components/layout/ThemeScript.astro';
import RevealController from '@/components/layout/RevealController.astro';
import { brand } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  jsonLd?: unknown;
  preloadImage?: string;
}
const { title = brand.title, description = brand.description, jsonLd, preloadImage } = Astro.props;
// Public-facing brand identity leads in the tab title and share cards.
// brand.title (the artist's real name) stays in JSON-LD Person.name for SEO.
const fullTitle = title === brand.title
  ? `${brand.publicName} -- ${brand.tagline}`
  : `${title} | ${brand.publicName}`;
const base = import.meta.env.BASE_URL;
const logoUrl = `${base}${brand.logo}`;
const appleIconUrl = `${base}logo-180.png`;
// Astro.site is configured in astro.config.mjs (https://sagargupta.online).
const SITE = Astro.site!;
const canonicalUrl = new URL(Astro.url.pathname, SITE).toString();
const absoluteLogoUrl = new URL(logoUrl, SITE).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#faf8f3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#15110d" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={logoUrl} type="image/jpeg" />
    <link rel="apple-touch-icon" sizes="180x180" href={appleIconUrl} />
    <link rel="canonical" href={canonicalUrl} />
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteLogoUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <title>{fullTitle}</title>
    <ThemeScript />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body id="top" class="font-body">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-[var(--color-ink)] focus:px-3 focus:py-2 focus:text-sm focus:text-[var(--color-bg)]"
    >
      Skip to content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <RevealController />
  </body>
</html>
