---
import { getCollection } from 'astro:content';
import Section from '@/components/layout/Section.astro';
import { placeholderDataUri } from '@/lib/placeholder';
import { type Artwork } from '@/lib/images';
import { sections, styles } from '@/lib/site';
import ArtworkImage from '@/components/ui/ArtworkImage.astro';
import Chromacard from '@/components/ui/Chromacard.astro';
import ArtworkLightbox from '@/components/ui/ArtworkLightbox.astro';

/* Map each art style to its CSS-variable accent. The card hover state, image
   border, and chromacard fallback all pull from this token, so a Pichwai card
   glows green-jade and a Madhubani card glows ruby. */
const styleAccentVar: Record<string, string> = {
  Madhubani: 'var(--style-madhubani)',
  Pichwai: 'var(--style-pichwai)',
  Lippan: 'var(--style-lippan)',
  Gond: 'var(--style-gond)',
  Texture: 'var(--style-texture)',
  'Mixed Media': 'var(--style-mixed)',
};

const all = await getCollection('artworks');
const baseUrl = import.meta.env.BASE_URL;
const w = sections.work;

/* Lightbox loads larger variants than the gallery thumbnail; reuse the same
   widths the optimize-images script generates. */
const LIGHTBOX_WIDTHS = [800, 1200];

const items = all
  .map((entry) => {
    const art = entry.data as Artwork;
    const slug = art.image ? art.image.replace(/\.(jpe?g|png)$/i, '') : '';
    const optBase = slug ? `${baseUrl}_opt/artworks/${slug}` : '';
    const origUrl = art.image ? `${baseUrl}artworks/${art.image}` : '';
    const avifSrcset = optBase
      ? LIGHTBOX_WIDTHS.map((w) => `${optBase}-${w}.avif ${w}w`).join(', ')
      : '';
    const webpSrcset = optBase
      ? LIGHTBOX_WIDTHS.map((w) => `${optBase}-${w}.webp ${w}w`).join(', ')
      : '';
    return {
      id: entry.id,
      slug: art.slug,
      title: art.title,
      style: art.style,
      medium: art.medium,
      year: art.year ?? null,
      aspectRatio: art.aspectRatio,
      filename: art.image || null,
      placeholder: art.image
        ? null
        : placeholderDataUri({
            title: art.title,
            style: art.style,
            width: 600,
            height: Math.round(600 / art.aspectRatio),
          }),
      description: art.description ?? null,
      alt: art.description ?? `${art.title}, ${art.style} painting in ${art.medium}.`,
      order: art.order,
      palette: art.palette,
      accentVar: styleAccentVar[art.style] ?? 'var(--color-accent)',
      origUrl,
      avifSrcset,
      webpSrcset,
    };
  })
  .sort((a, b) => a.order - b.order);

const filters = ['All', ...styles] as const;
---
<Section id="work" eyebrow={w.eyebrow} title={w.title} lead={w.lead}>
  <div data-gallery data-active="All">
    <div role="group" aria-label="Filter by style" class="mb-10 flex flex-wrap justify-center gap-2">
      {filters.map((f, i) => {
        const pillAccent = f === 'All' ? 'var(--color-ink)' : (styleAccentVar[f] ?? 'var(--color-accent)');
        return (
          <button
            type="button"
            data-filter={f}
            data-accent={pillAccent}
            aria-pressed={i === 0 ? 'true' : 'false'}
            style={`--pill-accent:${pillAccent};`}
            class:list={[
              'gallery-pill min-h-[40px] rounded-full border px-4 py-2.5 text-xs uppercase tracking-[0.16em] transition',
              i === 0
                ? 'pill-active'
                : 'border-[var(--color-line)] text-[var(--color-muted)]',
            ]}
          >
            {f}
          </button>
        );
      })}
    </div>

    <ul class="stagger grid grid-cols-2 gap-3 sm:gap-[var(--grid-gap)] lg:grid-cols-3">
      {items.map((it) => (
        <li
          class="gallery-item reveal"
          data-style={it.style}
          style={`--card-accent:${it.accentVar};`}
        >
          <article class="group flex flex-col gap-4">
            <button
              type="button"
              data-lightbox-trigger
              data-slug={it.slug}
              data-title={it.title}
              data-style={it.style}
              data-medium={it.medium}
              data-year={it.year ?? ''}
              data-description={it.description ?? ''}
              data-alt={it.alt}
              data-image={it.origUrl}
              data-avif-srcset={it.avifSrcset}
              data-webp-srcset={it.webpSrcset}
              data-palette={(it.palette ?? []).join('|')}
              data-accent={it.accentVar}
              aria-label={`Open ${it.title} in larger view`}
              class="gallery-frame relative grid w-full cursor-pointer place-items-center overflow-hidden border border-[var(--color-line)] bg-[var(--color-bg-soft)] aspect-[3/4] p-0 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--card-accent)] focus-visible:ring-offset-2"
            >
              {it.filename ? (
                <ArtworkImage
                  filename={it.filename}
                  alt={it.alt}
                  baseUrl={baseUrl}
                  imgClass="max-h-full max-w-full object-contain"
                />
              ) : (
                <img
                  src={it.placeholder!}
                  alt={it.alt}
                  loading="lazy"
                  decoding="async"
                  class="max-h-full max-w-full object-contain"
                />
              )}
            </button>
            <Chromacard
              palette={it.palette}
              fallback={it.accentVar}
              ariaLabel={`Palette for ${it.title}`}
            />
            <div class="flex flex-wrap items-baseline justify-between gap-x-2 gap-y-1">
              <h3 class="t-display text-base text-[var(--color-ink)] sm:text-xl">{it.title}</h3>
              <span class="t-meta text-[0.65rem] sm:text-xs" style={`color:${it.accentVar};`}>{it.style}</span>
            </div>
            {it.description && (
              <p class="font-body text-[0.78rem] leading-snug text-[var(--color-muted)] sm:text-sm">
                {it.description}
              </p>
            )}
            <p class="t-meta text-[0.65rem] normal-case tracking-normal text-[var(--color-muted)] sm:text-[0.7rem]">
              {it.medium}{it.year ? ` -- ${it.year}` : ''}
            </p>
          </article>
        </li>
      ))}
    </ul>

    <p data-empty aria-live="polite" class="t-body mt-6 hidden text-[var(--color-muted)]">
      No pieces in this style yet.
    </p>
  </div>

  <ArtworkLightbox />
</Section>

<script is:inline>
  (function () {
    const root = document.querySelector('[data-gallery]');
    if (!root) return;
    const items = root.querySelectorAll('.gallery-item');
    const pills = root.querySelectorAll('[data-filter]');
    const empty = root.querySelector('[data-empty]');

    function apply(filter) {
      let visible = 0;
      items.forEach((el) => {
        const match = filter === 'All' || el.getAttribute('data-style') === filter;
        el.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (empty) empty.classList.toggle('hidden', visible > 0);
      pills.forEach((p) => {
        const active = p.getAttribute('data-filter') === filter;
        p.setAttribute('aria-pressed', active ? 'true' : 'false');
        p.classList.toggle('pill-active', active);
        p.classList.toggle('border-[var(--color-line)]', !active);
        p.classList.toggle('text-[var(--color-muted)]', !active);
      });
      root.setAttribute('data-active', filter);
    }

    pills.forEach((p) => {
      p.addEventListener('click', () => apply(p.getAttribute('data-filter')));
    });
  })();
</script>
