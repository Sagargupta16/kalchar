{
	"name": "kalchar-by-megha",
	"version": "1.25.1",
	"private": true,
	"description": "Portfolio site for Megha Seth, traditional folk artist.",
	"license": "UNLICENSED",
	"packageManager": "pnpm@10.32.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"format": "biome format --write",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "tsx --env-file=.env.local scripts/migrate-json-to-db.ts",
		"db:images": "tsx --env-file=.env.local scripts/migrate-images-to-r2.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1062.0",
		"@neondatabase/serverless": "^1.1.0",
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"lenis": "^1.3.4",
		"lucide-react": "^1.17.0",
		"motion": "^12.0.0",
		"next": "^16.2.7",
		"next-auth": "5.0.0-beta.31",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-icons": "^5.6.0",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@tailwindcss/postcss": "^4.0.0",
		"@types/node": "^22.19.19",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.0.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"playwright": "^1.60.0",
		"postcss": "^8.5.0",
		"sharp": "^0.34.0",
		"tailwindcss": "^4.0.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"pnpm": {
		"overrides": {
			"postcss@<8.5.10": ">=8.5.10",
			"esbuild": ">=0.28.1"
		}
	}
}
