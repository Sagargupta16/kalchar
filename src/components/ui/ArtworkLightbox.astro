---
/* Native <dialog> lightbox for artwork detail views.
   - Zero dependencies. <dialog> handles focus trap, ESC-to-close, and the
     ::backdrop pseudo-element gives us a styled overlay for free.
   - Gallery cards in Work.astro carry data-lightbox-trigger; the controller
     here reads their data-* attributes (slug, title, style, medium, year,
     description, image, palette) and paints the dialog content on demand.
     This way only ONE dialog exists in the DOM regardless of catalog size.
   - Prev / next buttons + arrow keys cycle through siblings sharing the
     currently active filter, so the lightbox respects the gallery's
     filtered view. */
---
<dialog
  id="artwork-lightbox"
  class="artwork-lightbox bg-transparent p-0 backdrop:bg-[var(--color-ink)]/85 backdrop:backdrop-blur-sm"
  aria-labelledby="lightbox-title"
>
  <div class="relative mx-auto flex max-h-[90vh] w-[min(94vw,1100px)] flex-col overflow-hidden border border-[var(--color-line)] bg-[var(--color-bg)] md:flex-row">
    <button
      type="button"
      data-lightbox-close
      aria-label="Close"
      class="absolute right-3 top-3 z-10 grid h-9 w-9 place-items-center rounded-full border border-[var(--color-line)] bg-[var(--color-bg)] text-[var(--color-ink)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
    >
      <svg viewBox="0 0 20 20" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <line x1="4" y1="4" x2="16" y2="16"/>
        <line x1="16" y1="4" x2="4" y2="16"/>
      </svg>
    </button>

    <div class="lightbox-image relative flex min-h-[50vh] flex-1 items-center justify-center bg-[var(--color-bg-soft)] md:min-h-[70vh]">
      <picture data-lightbox-picture class="block h-full w-full">
        <img data-lightbox-img alt="" class="block h-full max-h-[90vh] w-full object-contain" />
      </picture>

      <button
        type="button"
        data-lightbox-prev
        aria-label="Previous artwork"
        class="lightbox-nav absolute left-3 top-1/2 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full border border-[var(--color-line)] bg-[var(--color-bg)]/85 text-[var(--color-ink)] backdrop-blur transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
      >
        <svg viewBox="0 0 20 20" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="12 5 6 10 12 15"/>
        </svg>
      </button>
      <button
        type="button"
        data-lightbox-next
        aria-label="Next artwork"
        class="lightbox-nav absolute right-3 top-1/2 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full border border-[var(--color-line)] bg-[var(--color-bg)]/85 text-[var(--color-ink)] backdrop-blur transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
      >
        <svg viewBox="0 0 20 20" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="8 5 14 10 8 15"/>
        </svg>
      </button>
    </div>

    <aside class="flex max-w-md flex-col gap-4 border-t border-[var(--color-line)] p-6 md:max-w-sm md:border-l md:border-t-0 md:p-8">
      <p class="t-eyebrow" data-lightbox-style></p>
      <h2 id="lightbox-title" class="t-display text-3xl text-[var(--color-ink)] sm:text-4xl" data-lightbox-title></h2>
      <p class="t-body text-[var(--color-muted)]" data-lightbox-description></p>
      <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-1 pt-2 text-sm">
        <dt class="t-meta">Medium</dt>
        <dd class="text-[var(--color-ink)]" data-lightbox-medium></dd>
        <dt class="t-meta" data-lightbox-year-label>Year</dt>
        <dd class="text-[var(--color-ink)]" data-lightbox-year></dd>
      </dl>
      <div class="mt-2" data-lightbox-palette-wrap>
        <p class="t-meta mb-2">Palette</p>
        <div class="chromacard" data-lightbox-palette role="img" aria-label="Sampled palette"></div>
      </div>
    </aside>
  </div>
</dialog>

<script is:inline>
  (function () {
    const dialog = document.getElementById('artwork-lightbox');
    if (!dialog) return;
    const imgEl = dialog.querySelector('[data-lightbox-img]');
    const pictureEl = dialog.querySelector('[data-lightbox-picture]');
    const titleEl = dialog.querySelector('[data-lightbox-title]');
    const styleEl = dialog.querySelector('[data-lightbox-style]');
    const descEl = dialog.querySelector('[data-lightbox-description]');
    const mediumEl = dialog.querySelector('[data-lightbox-medium]');
    const yearEl = dialog.querySelector('[data-lightbox-year]');
    const yearLabelEl = dialog.querySelector('[data-lightbox-year-label]');
    const paletteEl = dialog.querySelector('[data-lightbox-palette]');
    const paletteWrapEl = dialog.querySelector('[data-lightbox-palette-wrap]');
    const closeBtn = dialog.querySelector('[data-lightbox-close]');
    const prevBtn = dialog.querySelector('[data-lightbox-prev]');
    const nextBtn = dialog.querySelector('[data-lightbox-next]');

    /* The lightbox cycles only through *currently visible* gallery items, so a
       Madhubani filter restricts prev/next to Madhubani pieces. */
    function visibleTriggers() {
      return Array.from(document.querySelectorAll('[data-lightbox-trigger]'))
        .filter((el) => {
          const li = el.closest('.gallery-item');
          if (!li) return true;
          return getComputedStyle(li).display !== 'none';
        });
    }

    function paint(trigger) {
      const d = trigger.dataset;
      titleEl.textContent = d.title || '';
      styleEl.textContent = d.style || '';
      styleEl.style.color = d.accent || '';
      descEl.textContent = d.description || '';
      mediumEl.textContent = d.medium || '';
      if (d.year) {
        yearEl.textContent = d.year;
        yearLabelEl.style.display = '';
        yearEl.style.display = '';
      } else {
        yearLabelEl.style.display = 'none';
        yearEl.style.display = 'none';
      }
      const avif = d.avifSrcset || '';
      const webp = d.webpSrcset || '';
      const orig = d.image || '';
      while (pictureEl.firstChild) pictureEl.removeChild(pictureEl.firstChild);
      if (avif) {
        const s = document.createElement('source');
        s.type = 'image/avif';
        s.srcset = avif;
        pictureEl.appendChild(s);
      }
      if (webp) {
        const s = document.createElement('source');
        s.type = 'image/webp';
        s.srcset = webp;
        pictureEl.appendChild(s);
      }
      const img = document.createElement('img');
      img.src = orig;
      img.alt = d.alt || d.title || '';
      img.className = 'block h-full max-h-[90vh] w-full object-contain';
      pictureEl.appendChild(img);
      const palette = (d.palette || '').split('|').filter(Boolean);
      if (palette.length > 0) {
        paletteWrapEl.style.display = '';
        while (paletteEl.firstChild) paletteEl.removeChild(paletteEl.firstChild);
        palette.forEach((hex) => {
          const sw = document.createElement('span');
          sw.style.background = hex;
          paletteEl.appendChild(sw);
        });
      } else {
        paletteWrapEl.style.display = 'none';
      }
      dialog.dataset.activeSlug = d.slug || '';
    }

    function step(delta) {
      const triggers = visibleTriggers();
      if (triggers.length === 0) return;
      const slug = dialog.dataset.activeSlug;
      const idx = triggers.findIndex((t) => t.dataset.slug === slug);
      const nextIdx = idx === -1 ? 0 : (idx + delta + triggers.length) % triggers.length;
      paint(triggers[nextIdx]);
    }

    document.addEventListener('click', (e) => {
      const trigger = e.target.closest('[data-lightbox-trigger]');
      if (!trigger) return;
      e.preventDefault();
      paint(trigger);
      dialog.showModal();
    });

    closeBtn?.addEventListener('click', () => dialog.close());
    prevBtn?.addEventListener('click', () => step(-1));
    nextBtn?.addEventListener('click', () => step(1));

    /* Click outside the inner panel closes. <dialog>'s native click target is
       itself when the user clicks the backdrop, so we only close in that case. */
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft') step(-1);
      else if (e.key === 'ArrowRight') step(1);
    });
  })();
</script>

<style>
  /* Dialog ::backdrop animation -- subtle fade so opening doesn't slam.
     Honors prefers-reduced-motion via the global rule in globals.css.  */
  .artwork-lightbox[open] {
    animation: lightbox-in 240ms var(--ease-out-soft);
  }
  .artwork-lightbox[open]::backdrop {
    animation: backdrop-in 240ms var(--ease-out-soft);
  }
  @keyframes lightbox-in {
    from { opacity: 0; transform: translateY(8px) scale(0.98); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes backdrop-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .artwork-lightbox[open],
    .artwork-lightbox[open]::backdrop {
      animation: none;
    }
  }
</style>
