---
import { getCollection } from 'astro:content';
import { brand, styles } from '@/lib/site';
import { placeholderDataUri } from '@/lib/placeholder';
import { artworkUrl, type Artwork } from '@/lib/images';

const all = await getCollection('artworks');
const baseUrl = import.meta.env.BASE_URL;

/* Sort by 'order' so featured pieces come first; then walk all so the carousel cycles every piece. */
const slides = all
  .map((entry) => entry.data as Artwork)
  .sort((a, b) => {
    if (a.featured !== b.featured) return a.featured ? -1 : 1;
    return a.order - b.order;
  })
  .map((art) => ({
    title: art.title,
    style: art.style,
    image: art.image
      ? artworkUrl(art, baseUrl)
      : placeholderDataUri({ title: art.title, style: art.style, width: 720, height: 900 }),
  }));

const fallback = slides[0] ?? {
  title: brand.title,
  style: 'Madhubani' as const,
  image: placeholderDataUri({ title: brand.title, style: 'Madhubani', width: 720, height: 900 }),
};
---
<section class="relative overflow-hidden border-b border-[var(--color-line)]">
  <div class="container-x grid gap-10 py-16 sm:gap-12 sm:py-24 md:grid-cols-12 md:items-center md:gap-10 md:py-32">
    <div class="stagger md:col-span-7">
      <p class="t-eyebrow reveal mb-4 sm:mb-5">{brand.tagline}</p>
      <h1 class="t-display reveal text-5xl text-[var(--color-ink)] sm:text-6xl md:text-[7rem] md:leading-[0.95] lg:text-[7.5rem]">
        {brand.title}
        <span aria-hidden="true" class="ml-2 align-middle font-devanagari text-[0.5em] not-italic text-[var(--color-accent)] sm:ml-3">
          {brand.devanagariMark}
        </span>
      </h1>
      <p class="t-lead reveal mt-5 max-w-xl sm:mt-7">{brand.description}</p>
      <ul class="reveal mt-7 flex flex-wrap gap-x-2 gap-y-2 sm:mt-10 sm:gap-x-3">
        {styles.map((s) => (
          <li class="t-meta rounded-full border border-[var(--color-line)] px-3 py-1">{s}</li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-5">
      <div
        id="hero-frame"
        data-carousel
        class="parallax-frame relative mx-auto aspect-[3/4] w-full max-w-md md:max-w-none"
      >
        <div
          class="absolute inset-0 border border-[var(--color-line)] bg-[var(--color-bg-soft)]"
          style="transform: translate(-1rem, 1rem) translateZ(-30px);"
        ></div>

        <div class="relative h-full w-full overflow-hidden border border-[var(--color-line)] bg-[var(--color-bg-soft)]">
          {slides.map((s, i) => (
            <img
              src={s.image}
              alt={`${s.title}, ${s.style}`}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              data-slide
              data-index={i}
              class="absolute inset-0 h-full w-full object-cover transition-opacity duration-1000 ease-out"
              style={`opacity:${i === 0 ? 1 : 0}`}
            />
          ))}
        </div>

        <div class="absolute -bottom-7 left-0 right-0 flex items-center justify-between gap-4">
          <p class="t-meta truncate text-[var(--color-muted)]" data-caption>
            {fallback.title} · {fallback.style}
          </p>
          <div class="flex items-center gap-1.5" aria-hidden="true">
            {slides.slice(0, Math.min(slides.length, 8)).map((_, i) => (
              <span
                data-dot
                data-index={i}
                class={`h-1 transition-all duration-500 ${i === 0 ? 'w-6 bg-[var(--color-accent)]' : 'w-2 bg-[var(--color-line)]'}`}
              />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      if (typeof window === 'undefined') return;
      const root = document.querySelector('[data-carousel]');
      if (!root) return;
      const slides = Array.from(root.querySelectorAll('[data-slide]'));
      const dots = Array.from(root.querySelectorAll('[data-dot]'));
      const caption = root.querySelector('[data-caption]');
      if (slides.length <= 1) return;

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let index = 0;
      let timer = 0;
      const INTERVAL = 4500;
      const dotsLen = dots.length;

      function show(i) {
        slides.forEach((s, n) => {
          s.style.opacity = n === i ? '1' : '0';
        });
        if (caption) {
          caption.textContent = slides[i].alt;
        }
        if (dotsLen > 0) {
          const activeDot = i % dotsLen;
          dots.forEach((d, n) => {
            const on = n === activeDot;
            d.className = `h-1 transition-all duration-500 ${on ? 'w-6 bg-[var(--color-accent)]' : 'w-2 bg-[var(--color-line)]'}`;
          });
        }
        index = i;
      }

      function tick() {
        show((index + 1) % slides.length);
      }

      function start() {
        if (reduceMotion) return;
        stop();
        timer = window.setInterval(tick, INTERVAL);
      }

      function stop() {
        if (timer) {
          window.clearInterval(timer);
          timer = 0;
        }
      }

      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);

      // Pause when tab is hidden (no point cycling unwatched)
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop();
        else start();
      });

      start();
    })();
  </script>

  <script is:inline>
    (function () {
      if (typeof window === 'undefined') return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (window.matchMedia('(hover: none)').matches) return;
      const frame = document.getElementById('hero-frame');
      if (!frame) return;
      const inner = frame.querySelector('div.relative');
      const shadow = frame.querySelector('div.absolute.inset-0');
      if (!inner || !shadow) return;
      let raf = 0;
      function onMove(e) {
        const r = frame.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          inner.style.transform = `perspective(1000px) rotateX(${(-y * 6).toFixed(2)}deg) rotateY(${(x * 8).toFixed(2)}deg)`;
          shadow.style.transform = `perspective(1000px) translate(${(x * 18 - 16).toFixed(1)}px, ${(y * 18 + 16).toFixed(1)}px) translateZ(-30px)`;
        });
      }
      function reset() {
        inner.style.transform = '';
        shadow.style.transform = 'translate(-1rem, 1rem) translateZ(-30px)';
      }
      frame.addEventListener('mousemove', onMove);
      frame.addEventListener('mouseleave', reset);
    })();
  </script>
</section>
