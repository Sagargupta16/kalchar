---
interface Props {
  as?: 'article' | 'li' | 'div';
  interactive?: boolean;
  class?: string;
}
const { as = 'div', interactive = false, class: className = '' } = Astro.props;
const Tag = as as 'article' | 'li' | 'div';
const interactiveClass = interactive
  ? 'cursor-pointer hover:border-[var(--color-accent)] hover:-translate-y-0.5 hover:shadow-[0_18px_40px_-28px_color-mix(in_srgb,var(--color-accent)_70%,transparent)]'
  : '';
---
<Tag
  class={`relative flex flex-col gap-4 border border-[var(--color-line)] bg-[var(--color-bg-soft)] p-5 transition motion-safe:duration-500 motion-safe:ease-out ${interactiveClass} ${className}`}
>
  <slot />
</Tag>
